<?php
namespace App\Http\Controllers\Admin;

use App\Http\Controllers\Controller;
use App\Models\Dashboard;
use Illuminate\Support\Facades\Auth;
use App\Models\Student;
use App\Models\Admission;
use App\Models\User;
use App\Models\Payment;
use App\Models\Expense;
use App\Models\Course;
use App\Models\Batch;
use App\Models\StudentFee; // New component-based model
use App\Models\Attendance;
use Spatie\Activitylog\Models\Activity;
use Illuminate\Support\Facades\DB;
use Carbon\Carbon;

class DashboardController extends Controller
{
    public function index()
    {
        $user = Auth::user();
        $dashboard = Dashboard::whereHas('role', fn($q) => $q->where('name', $user->roles->first()->name ?? ''))->first();
        
        // Check if dynamic dashboard exists
        if ($dashboard && $dashboard->widgets()->exists()) {
            $layout = $dashboard->widgets()->orderBy('pivot_row')->orderBy('pivot_col')->get();
            $widgetData = $this->getWidgetData();
            
            // Check if dynamic view exists, fallback to index if not
            if (view()->exists('admin.dashboard.dynamic')) {
                return view('admin.dashboard.dynamic', compact('layout', 'widgetData'));
            }
        }
        
        $data = $this->getWidgetData();
        
        // Check if admin dashboard index exists, fallback to generic dashboard
        if (view()->exists('admin.dashboard.index')) {
            return view('admin.dashboard.index', $data);
        } else {
            return view('admin.dashboard', $data);
        }
    }
    
    public function getWidgetData()
    {
        $data = [];
        
        // ===================================
        // BASIC STATS CARDS (Updated for Component System)
        // ===================================
        $data['totalStudents'] = Student::where('status', 'active')->count();
        $data['pendingAdmissionsCount'] = Admission::where('status', 'pending')->count();
        $data['totalFaculty'] = User::role('staff')->count();
        $data['totalCourses'] = Course::count();
        $data['totalBatches'] = Batch::count();
        $data['totalAlumni'] = Student::where('status', 'graduated')->count();

        // ===================================
        // FINANCIAL METRICS (Component-Based System)
        // ===================================
        
        // Current month's component-based payments
        $data['feesCollectedThisMonth'] = Payment::where('payment_type', 'component')
            ->whereMonth('payment_date', Carbon::now()->month)
            ->whereYear('payment_date', Carbon::now()->year)
            ->sum('amount');

        // Total outstanding dues from student fees (component system)
        $data['totalOutstandingDues'] = $this->calculateTotalOutstandingDues();

        // Collection efficiency metrics
        $data['collectionEfficiency'] = $this->calculateCollectionEfficiency();

        // Overdue fees count
        $data['overdueFees'] = $this->getOverdueFees();

        // ===================================
        // STUDENT DISTRIBUTION CHART
        // ===================================
        $studentDistribution = Student::where('status', 'active')
            ->join('batches', 'students.batch_id', '=', 'batches.id')
            ->join('courses', 'batches.course_id', '=', 'courses.id')
            ->select('courses.name as course_name', DB::raw('count(students.id) as student_count'))
            ->groupBy('courses.name')
            ->get();
        
        $data['courseLabels'] = $studentDistribution->pluck('course_name');
        $data['courseData'] = $studentDistribution->pluck('student_count');

        // ===================================
        // FINANCIAL OVERVIEW CHART (Enhanced)
        // ===================================
        $financialLabels = [];
        $incomeData = [];
        $expenseData = [];
        $componentPaymentData = [];
        
        for($i = 29; $i >= 0; $i--) {
            $date = Carbon::now()->subDays($i);
            $financialLabels[] = $date->format('M d');
            
            // All payments (legacy + component)
            $incomeData[] = Payment::whereDate('payment_date', $date)->sum('amount');
            
            // Component payments specifically
            $componentPaymentData[] = Payment::where('payment_type', 'component')
                ->whereDate('payment_date', $date)
                ->sum('amount');
            
            // Expenses
            $expenseData[] = Expense::whereDate('expense_date', $date)->sum('amount');
        }
        
        $data['financialLabels'] = $financialLabels;
        $data['incomeData'] = $incomeData;
        $data['componentPaymentData'] = $componentPaymentData;
        $data['expenseData'] = $expenseData;

        // ===================================
        // PAYMENT METHOD DISTRIBUTION
        // ===================================
        $data['paymentMethodDistribution'] = $this->getPaymentMethodDistribution();

        // ===================================
        // FEE CATEGORY BREAKDOWN
        // ===================================
        $data['feeCategoryBreakdown'] = $this->getFeeCategoryBreakdown();

        // ===================================
        // ATTENDANCE CHART (Fixed and Enhanced)
        // ===================================
        $attendanceLabels = [];
        $presentData = [];
        $absentData = [];
        $attendanceRateData = [];
        
        for($i = 29; $i >= 0; $i--) {
            $date = Carbon::now()->subDays($i);
            
            // Skip weekends for attendance (customize as needed)
            if (!$date->isWeekend()) {
                $attendanceLabels[] = $date->format('M d');
                
                $presentCount = Attendance::whereDate('attendance_date', $date)
                    ->where('status', 'present')
                    ->count();
                    
                $absentCount = Attendance::whereDate('attendance_date', $date)
                    ->where('status', 'absent')
                    ->count();
                
                $presentData[] = $presentCount;
                $absentData[] = $absentCount;
                
                // Calculate attendance rate
                $totalStudents = $presentCount + $absentCount;
                $attendanceRate = $totalStudents > 0 ? round(($presentCount / $totalStudents) * 100, 1) : 0;
                $attendanceRateData[] = $attendanceRate;
            }
        }
        
        $data['attendanceLabels'] = $attendanceLabels;
        $data['presentData'] = $presentData;
        $data['absentData'] = $absentData;
        $data['attendanceRateData'] = $attendanceRateData;

        // ===================================
        // PAYMENT DEFAULTERS (Component-Based)
        // ===================================
        $data['paymentDefaulters'] = $this->getPaymentDefaulters();

        // ===================================
        // RECENT ACTIVITIES (Enhanced)
        // ===================================
        $data['latestActivities'] = Activity::with('causer')
            ->latest()
            ->limit(10)
            ->get();

        // ===================================
        // FINANCIAL SUMMARY CARDS
        // ===================================
        $data['financialSummary'] = $this->getFinancialSummary();

        return $data;
    }

    // ===================================
    // HELPER METHODS FOR COMPONENT SYSTEM
    // ===================================

    /**
     * Calculate total outstanding dues from component system
     */
    private function calculateTotalOutstandingDues()
    {
        return StudentFee::whereIn('status', ['unpaid', 'partial', 'overdue'])
            ->get()
            ->sum(function($fee) {
                $remaining = ($fee->amount ?? 0) - ($fee->paid_amount ?? 0) - ($fee->concession_amount ?? 0);
                return max(0, $remaining);
            });
    }

    /**
     * Calculate collection efficiency
     */
    private function calculateCollectionEfficiency()
    {
        $totalBilled = StudentFee::sum('amount') ?? 0;
        $totalConcessions = StudentFee::sum('concession_amount') ?? 0;
        $totalCollected = StudentFee::sum('paid_amount') ?? 0;
        
        $netBilled = $totalBilled - $totalConcessions;
        
        if ($netBilled <= 0) {
            return 100; // No fees billed or all concessions
        }
        
        return round(($totalCollected / $netBilled) * 100, 2);
    }

    /**
     * Get overdue fees count
     */
    private function getOverdueFees()
    {
        return StudentFee::where('due_date', '<', Carbon::now())
            ->whereIn('status', ['unpaid', 'partial'])
            ->whereRaw('amount - paid_amount - concession_amount > 0')
            ->count();
    }

    /**
     * Get payment method distribution
     */
    private function getPaymentMethodDistribution()
    {
        return Payment::where('payment_type', 'component')
            ->whereMonth('payment_date', Carbon::now()->month)
            ->whereYear('payment_date', Carbon::now()->year)
            ->select('payment_method', DB::raw('count(*) as count'), DB::raw('sum(amount) as total'))
            ->groupBy('payment_method')
            ->get()
            ->mapWithKeys(function($item) {
                return [
                    ucfirst($item->payment_method) => [
                        'count' => $item->count,
                        'total' => $item->total
                    ]
                ];
            });
    }

    /**
     * Get fee category breakdown
     */
    private function getFeeCategoryBreakdown()
    {
        return StudentFee::join('fee_categories', 'student_fees.fee_category_id', '=', 'fee_categories.id')
            ->select(
                'fee_categories.name as category_name',
                DB::raw('sum(student_fees.amount) as total_billed'),
                DB::raw('sum(student_fees.paid_amount) as total_collected'),
                DB::raw('sum(student_fees.amount - student_fees.paid_amount - student_fees.concession_amount) as outstanding')
            )
            ->groupBy('fee_categories.id', 'fee_categories.name')
            ->get();
    }

    /**
     * Get payment defaulters (students with overdue fees)
     */
    private function getPaymentDefaulters()
    {
        return Student::whereHas('studentFees', function($query) {
                $query->where('due_date', '<', Carbon::now())
                      ->whereIn('status', ['unpaid', 'partial'])
                      ->whereRaw('amount - paid_amount - concession_amount > 0');
            })
            ->with(['batch.course', 'studentFees' => function($query) {
                $query->where('due_date', '<', Carbon::now())
                      ->whereIn('status', ['unpaid', 'partial'])
                      ->whereRaw('amount - paid_amount - concession_amount > 0')
                      ->with('feeCategory');
            }])
            ->limit(10)
            ->get()
            ->map(function($student) {
                $overdueAmount = $student->studentFees->sum(function($fee) {
                    return max(0, ($fee->amount ?? 0) - ($fee->paid_amount ?? 0) - ($fee->concession_amount ?? 0));
                });
                
                return [
                    'student' => $student,
                    'overdue_amount' => $overdueAmount,
                    'overdue_components' => $student->studentFees->count()
                ];
            });
    }

    /**
     * Get comprehensive financial summary
     */
    private function getFinancialSummary()
    {
        $today = Carbon::now();
        $thisMonth = $today->copy()->startOfMonth();
        $lastMonth = $today->copy()->subMonth();
        
        // This month's collections
        $thisMonthCollections = Payment::where('payment_type', 'component')
            ->whereBetween('payment_date', [$thisMonth, $today])
            ->sum('amount');
            
        // Last month's collections
        $lastMonthCollections = Payment::where('payment_type', 'component')
            ->whereBetween('payment_date', [$lastMonth->startOfMonth(), $lastMonth->endOfMonth()])
            ->sum('amount');
            
        // Calculate growth
        $growthPercentage = 0;
        if ($lastMonthCollections > 0) {
            $growthPercentage = round((($thisMonthCollections - $lastMonthCollections) / $lastMonthCollections) * 100, 2);
        }

        return [
            'this_month_collections' => $thisMonthCollections,
            'last_month_collections' => $lastMonthCollections,
            'growth_percentage' => $growthPercentage,
            'total_outstanding' => $this->calculateTotalOutstandingDues(),
            'collection_efficiency' => $this->calculateCollectionEfficiency(),
            'overdue_count' => $this->getOverdueFees()
        ];
    }
}