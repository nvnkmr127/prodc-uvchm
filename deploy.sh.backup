#!/bin/bash
set -e

echo "🚀 UVCHM Production Deployment from GitHub"
echo "==========================================="

# Configuration
APP_DIR="/home/digiclou/portal.uvchm.com"
BACKUP_DIR="/home/digiclou/backups"
LOG_FILE="/home/digiclou/deployment.log"
GITHUB_BRANCH="${1:-main}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging function
log() {
    echo -e "[$(date +'%Y-%m-%d %H:%M:%S')] $1" | tee -a $LOG_FILE
}

# Error handling function
error_exit() {
    log "${RED}❌ Error: $1${NC}"
    log "Bringing application back online..."
    php artisan up 2>/dev/null || true
    exit 1
}

# Find Composer executable
find_composer() {
    local composer_cmd=""
    
    # Check common locations and commands
    if command -v composer &> /dev/null; then
        composer_cmd="composer"
    elif [ -f "/usr/local/bin/composer" ]; then
        composer_cmd="/usr/local/bin/composer"
    elif [ -f "/usr/bin/composer" ]; then
        composer_cmd="/usr/bin/composer"
    elif [ -f "$HOME/.composer/vendor/bin/composer" ]; then
        composer_cmd="$HOME/.composer/vendor/bin/composer"
    elif [ -f "./composer.phar" ]; then
        composer_cmd="php composer.phar"
    elif [ -f "/usr/local/bin/composer.phar" ]; then
        composer_cmd="php /usr/local/bin/composer.phar"
    else
        # Try to download composer if not found
        log "${YELLOW}⚠️ Composer not found. Attempting to download...${NC}"
        curl -sS https://getcomposer.org/installer | php
        if [ -f "composer.phar" ]; then
            composer_cmd="php composer.phar"
        else
            error_exit "Composer could not be found or downloaded"
        fi
    fi
    
    log "${GREEN}✅ Found Composer: $composer_cmd${NC}"
    echo $composer_cmd
}

# Main deployment function
main() {
    cd $APP_DIR || error_exit "Cannot change to application directory: $APP_DIR"
    
    # Create backup directory
    mkdir -p $BACKUP_DIR
    
    # Find Composer
    COMPOSER_CMD=$(find_composer)
    
    # Put in maintenance mode
    log "${YELLOW}🔧 Putting application in maintenance mode...${NC}"
    php artisan down --render="errors::503" --secret="uvchm-deploy-$(date +%s)" || true
    
    # Create backup
    log "${YELLOW}💾 Creating database backup...${NC}"
    php artisan backup:run --only-db --filename="pre-deployment-$(date +%Y%m%d_%H%M%S).zip" || log "${YELLOW}⚠️ Backup failed but 
continuing${NC}"
    
    # Fetch latest changes from GitHub
    log "${YELLOW}📥 Fetching latest changes from GitHub...${NC}"
    git fetch origin $GITHUB_BRANCH || error_exit "Failed to fetch from GitHub"
    
    # Show what will be deployed
    local current_commit=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    local new_commit=$(git rev-parse --short origin/$GITHUB_BRANCH)
    log "Current: $current_commit → New: $new_commit"
    
    # Stash any local changes
    log "${YELLOW}💾 Stashing local changes...${NC}"
    git stash push -m "Auto-stash before deployment $(date)" || true
    
    # Reset to latest GitHub version
    log "${YELLOW}🔄 Updating code from GitHub...${NC}"
    git reset --hard origin/$GITHUB_BRANCH || error_exit "Failed to update code"
    
    # Install dependencies
    log "${YELLOW}📦 Installing dependencies...${NC}"
    $COMPOSER_CMD install --no-dev --optimize-autoloader --no-interaction || error_exit "Composer install failed"
    
    # Clear caches
    log "${YELLOW}🧹 Clearing caches...${NC}"
    php artisan config:clear || true
    php artisan cache:clear || true
    php artisan route:clear || true
    php artisan view:clear || true
    
    # Run migrations
    log "${YELLOW}🗄️ Running migrations...${NC}"
    php artisan migrate --force || error_exit "Database migrations failed"
    
    # Cache for production
    log "${YELLOW}⚡ Optimizing for production...${NC}"
    php artisan config:cache || true
    php artisan route:cache || true
    php artisan view:cache || true
    php artisan optimize || true
    
    # Set permissions
    log "${YELLOW}🔒 Setting permissions...${NC}"
    find storage -type f -exec chmod 664 {} \; 2>/dev/null || true
    find storage -type d -exec chmod 775 {} \; 2>/dev/null || true
    find bootstrap/cache -type f -exec chmod 664 {} \; 2>/dev/null || true
    find bootstrap/cache -type d -exec chmod 775 {} \; 2>/dev/null || true
    chown -R digiclou:digiclou storage bootstrap/cache 2>/dev/null || true
    
    # Create storage link if needed
    if [ ! -L "public/storage" ]; then
        log "${YELLOW}🔗 Creating storage link...${NC}"
        php artisan storage:link || true
    fi
    
    # Health check
    log "${YELLOW}🏥 Running health check...${NC}"
    php artisan uvchm:health-check --quick || log "${YELLOW}⚠️ Health check failed but continuing${NC}"
    
    # Bring back online
    log "${YELLOW}🌐 Bringing application online...${NC}"
    php artisan up || error_exit "Failed to bring application online"
    
    local final_commit=$(git rev-parse --short HEAD)
    log "${GREEN}✅ Deployment completed! Now running: $final_commit${NC}"
    log "${GREEN}🌐 https://portal.uvchm.com${NC}"
    
    # Display summary
    echo ""
    echo "================================="
    echo "📊 DEPLOYMENT SUMMARY"
    echo "================================="
    echo "🕐 Completed: $(date)"
    echo "📝 Previous: $current_commit"
    echo "📝 Current: $final_commit"
    echo "🌐 URL: https://portal.uvchm.com"
    echo "📝 Log: $LOG_FILE"
    echo "================================="
}

# Trap to ensure application comes back online on script interruption
trap 'log "Script interrupted! Bringing application back online..."; php artisan up 2>/dev/null || true; exit 1' INT TERM

# Run main function
main "$@"
