{
    "openapi": "3.0.0",
    "info": {
        "title": "School Management System API",
        "description": "API documentation for School Management System - Complete student management, attendance tracking, and administrative operations.",
        "contact": {
            "name": "API Support",
            "email": "admin@uvchm.com"
        },
        "license": {
            "name": "MIT",
