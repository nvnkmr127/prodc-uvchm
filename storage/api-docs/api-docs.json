        },
        {
            "url": "http://localhost:8000",
            "description": "Development Server"
        }
    ],
    "paths": {
        "/api/v1/test": {
            "get": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Test API connection",
                "description": "Simple endpoint to test if API is working and authentication is successful",
                "operationId": "testApi",
                "responses": {
                    "200": {
                        "description": "API is working correctly",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "API is working!"
                                        },
                                        "user": {
                                            "type": "string",
                                            "example": "John Doe"
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "example": "2025-01-01T12:00:00Z"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/students/search": {
            "get": {
                "tags": [
                    "Students"
                ],
                "summary": "Search for students",
                "description": "Search for students by name, enrollment number, or mobile number",
                "operationId": "searchStudents",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Search query (name, enrollment number, or mobile)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "john"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Students found successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "example": "John Doe"
                                                    },
                                                    "enrollment_number": {
                                                        "type": "string",
                                                        "example": "ENR-12345678"
                                                    },
                                                    "course": {
                                                        "type": "string",
                                                        "example": "Hotel Management"
                                                    },
                                                    "batch": {
                                                        "type": "string",
                                                        "example": "2024-2025 Batch"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/attendance": {
            "post": {
                "tags": [
                    "Attendance"
                ],
                "summary": "Submit attendance record",
                "description": "Submit attendance record from biometric device or manual entry",
                "operationId": "submitAttendance",
                "parameters": [
                    {
                        "name": "X-API-KEY",
                        "in": "header",
                        "description": "Biometric device API key",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "enrollment_number"
                                ],
                                "properties": {
                                    "enrollment_number": {
                                        "type": "string",
                                        "example": "ENR-12345678"
                                    },
                                    "timestamp": {
                                        "description": "Unix timestamp (optional)",
                                        "type": "integer",
                                        "example": 1672531200
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Attendance recorded successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Attendance recorded for John Doe"
                                        },
                                        "data": {
                                            "properties": {
                                                "student_id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "attendance_date": {
                                                    "type": "string",
                                                    "format": "date",
                                                    "example": "2025-01-15"
                                                },
                                                "status": {
                                                    "type": "string",
                                                    "example": "present"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Invalid API key",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "error"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthorized"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "Student": {
                "title": "Student",
                "description": "Student model",
                "properties": {
                    "id": {
                        "description": "Student ID",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "Student full name",
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "description": "Student email address",
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "enrollment_number": {
                        "description": "Unique enrollment number",
                        "type": "string",
                        "example": "ENR-12345678"
                    },
                    "gender": {
                        "description": "Student gender",
                        "type": "string",
                        "enum": [
                            "Male",
                            "Female",
                            "Other"
                        ],
                        "example": "Male"
                    },
                    "student_mobile": {
                        "description": "Student mobile number",
                        "type": "string",
                        "example": "9876543210"
                    },
                    "father_name": {
                        "description": "Father's name",
                        "type": "string",
                        "example": "John Doe Sr."
                    },
                    "father_mobile": {
                        "description": "Father's mobile number",
                        "type": "string",
                        "example": "9876543211"
                    },
                    "village": {
                        "description": "Student's village/city",
                        "type": "string",
                        "example": "New York"
                    },
                    "admission_date": {
                        "description": "Date of admission",
                        "type": "string",
                        "format": "date",
                        "example": "2024-01-15"
                    },
                    "status": {
                        "description": "Student status",
                        "type": "string",
                        "enum": [
                            "active",
                            "graduated",
                            "dropout"
                        ],
                        "example": "active"
                    },
                    "batch_id": {
                        "description": "Batch ID",
                        "type": "integer",
                        "example": 1
                    },
                    "photo": {
                        "description": "Student photo path",
                        "type": "string",
                        "example": "photos/student1.jpg",
                        "nullable": true
                    },
                    "current_employer": {
                        "description": "Current employer (for alumni)",
                        "type": "string",
                        "example": "ABC Hotel",
                        "nullable": true
                    },
                    "job_title": {
                        "description": "Current job title (for alumni)",
                        "type": "string",
                        "example": "Manager",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-15T10:30:00Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-15T10:30:00Z"
                    }
                },
                "type": "object"
            },
            "Attendance": {
                "title": "Attendance",
                "description": "Attendance record model",
                "properties": {
                    "id": {
                        "description": "Attendance record ID",
                        "type": "integer",
                        "example": 1
                    },
                    "student_id": {
                        "description": "Student ID",
                        "type": "integer",
                        "example": 1
                    },
                    "batch_id": {
                        "description": "Batch ID",
                        "type": "integer",
                        "example": 1
                    },
                    "faculty_id": {
                        "description": "Faculty ID who marked attendance",
                        "type": "integer",
                        "example": 1
                    },
                    "attendance_date": {
                        "description": "Date of attendance",
                        "type": "string",
                        "format": "date",
