                        "example": "2024-01-15T10:30:00Z"
                    }
                },
                "type": "object"
            },
            "ApiResponse": {
                "title": "Standard API Response",
                "description": "Standard API response format",
                "properties": {
                    "success": {
                        "description": "Indicates if the request was successful",
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "description": "Response message",
                        "type": "string",
                        "example": "Operation completed successfully"
                    },
                    "data": {
                        "description": "Response data",
                        "type": "object"
                    },
                    "timestamp": {
                        "description": "Response timestamp",
                        "type": "string",
                        "format": "date-time",
                        "example": "2025-01-15T10:30:00Z"
                    }
                },
                "type": "object"
            },
            "PaginatedResponse": {
                "title": "Paginated Response",
                "description": "Paginated API response format",
                "properties": {
                    "data": {
                        "description": "Array of data items",
                        "type": "array",
                        "items": {
                            "type": "object"
                        }
                    },
                    "links": {
                        "properties": {
                            "first": {
                                "type": "string",
                                "example": "https://example.com/api/resource?page=1"
                            },
                            "last": {
                                "type": "string",
                                "example": "https://example.com/api/resource?page=10"
                            },
                            "prev": {
                                "type": "string",
                                "example": "https://example.com/api/resource?page=1",
                                "nullable": true
                            },
                            "next": {
                                "type": "string",
                                "example": "https://example.com/api/resource?page=3",
                                "nullable": true
                            }
                        },
                        "type": "object"
                    },
                    "meta": {
                        "properties": {
                            "current_page": {
                                "type": "integer",
                                "example": 2
                            },
                            "from": {
                                "type": "integer",
                                "example": 11
                            },
                            "last_page": {
                                "type": "integer",
                                "example": 10
                            },
                            "per_page": {
                                "type": "integer",
                                "example": 10
                            },
                            "to": {
                                "type": "integer",
                                "example": 20
                            },
                            "total": {
                                "type": "integer",
                                "example": 95
                            }
                        },
                        "type": "object"
                    }
                },
                "type": "object"
            }
