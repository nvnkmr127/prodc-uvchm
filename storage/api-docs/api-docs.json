                        "example": 1
                    },
                    "student_id": {
                        "description": "Student ID",
                        "type": "integer",
                        "example": 1
                    },
                    "invoice_number": {
                        "description": "Unique invoice number",
                        "type": "string",
                        "example": "INV-2025-001"
                    },
                    "issue_date": {
                        "description": "Invoice issue date",
                        "type": "string",
                        "format": "date",
                        "example": "2025-01-15"
                    },
                    "due_date": {
                        "description": "Payment due date",
                        "type": "string",
                        "format": "date",
                        "example": "2025-02-15"
                    },
                    "total_amount": {
                        "description": "Total invoice amount",
                        "type": "number",
                        "format": "float",
                        "example": 50000
                    },
                    "paid_amount": {
                        "description": "Amount paid",
                        "type": "number",
                        "format": "float",
                        "example": 30000
                    },
                    "due_amount": {
                        "description": "Amount due",
                        "type": "number",
